{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": false,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@ft/ui/*": ["../../packages/ui/src/*"],
      "@/components/ui/*": ["../../packages/ui/src/ui/*"],
      "@/components/ui": ["../../packages/ui/src/ui"],
      "@/components/shared/*": ["../../packages/ui/src/shared/*"],
      "@/components/shared": ["../../packages/ui/src/shared"],
      "@/utils/*": ["../../packages/ui/src/utils/*"],
      "@/utils": ["../../packages/ui/src/utils"],
      "@/@types/common": ["../../packages/ui/src/@types/common"],
      "@/@types/theme": ["../../packages/ui/src/@types/theme"],
      "@/@types/navigation": ["../../packages/ui/src/@types/navigation"],
      "@/@types/routes": ["../../packages/ui/src/@types/routes"],
      "@/store/themeStore": ["../../packages/ui/src/store/themeStore"],
      "@/store/localeStore": ["../../packages/ui/src/store/localeStore"],
      "@/configs/theme.config": ["../../packages/ui/src/configs/theme.config"],
      "@/configs/preset-theme-schema.config": ["../../packages/ui/src/configs/preset-theme-schema.config"],
      "@/configs/app.config": ["../../packages/ui/src/configs/app.config"],
      "@/locales": ["../../packages/ui/src/locales"],
      "@/locales/*": ["../../packages/ui/src/locales/*"],
      "@/*": ["./src/*"],
      "@ft/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@chaibuilder/sdk/runtime": ["./node_modules/@chaibuilder/sdk/dist/runtime.d.ts"],
      "@chaibuilder/sdk/web-blocks": ["./node_modules/@chaibuilder/sdk/dist/web-blocks.d.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
