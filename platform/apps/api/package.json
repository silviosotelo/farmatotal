    "@fastify/swagger-ui": "^5.2.1",
    "@platform/shared-types": "workspace:*",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "drizzle-zod": "^0.6.1",
    "fastify": "^5.2.1",
