# Heredar de ../../.env del monorepo o sobrescribir aca.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://localhost:6379
API_PORT=4000
JWT_ACCESS_SECRET=cambiar-32-chars-min
