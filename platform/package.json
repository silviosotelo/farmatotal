{
  "name": "farmatotal-platform",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:gen": "pnpm --filter @ft/api db:gen",
    "db:push": "pnpm --filter @ft/api db:push",
    "db:migrate": "pnpm --filter @ft/api db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "zod": "4.4.3"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
