# Compartido (Turbo lo lee como globalDependencies)
NODE_ENV=development

# === DB ===
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# Ejemplo docker local:
# DATABASE_URL=postgres://farmatotal:farmatotal@localhost:5434/farmatotal_app

# === Redis (BullMQ) ===
REDIS_URL=redis://localhost:6379

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=farmatotal-media
S3_ACCESS_KEY=farmatotal
S3_SECRET_KEY=farmatotal_minio_dev
S3_FORCE_PATH_STYLE=true

# === Auth ===
JWT_ACCESS_SECRET=cambiar-32-chars-min
JWT_REFRESH_SECRET=cambiar-32-chars-min-distinto
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost

# === URLs publicas ===
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
ADMIN_PUBLIC_URL=http://localhost:5173
STORE_PUBLIC_URL=http://localhost:3000

# === CORS allow-list (coma separada) ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
